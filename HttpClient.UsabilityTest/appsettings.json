{
  "Logging": {
    "LogLevel": {
      "Default": "None",
      "Microsoft.AspNetCore": "None"
    }
  },
  "AllowedHosts": "*",
  "ServiceClients": {
    "FakeService": {
      "BaseUrl": "https://jsonplaceholder.typicode.com",
      "TimeoutSeconds": 5,
      "Retry": {
        "MaxAttempts": 10,
        "BaseDelayMilliseconds": 999,
        "DelayBackoffType": "Exponential",
        "RetryableStatusCodes": [408, 429, 500, 502, 503, 504]
      }
    },
    "WeatherService": {
      "BaseUrl": "http://localhost:5078",
      "TimeoutSeconds": 30,
      "Retry": {
        "Enabled": true,
        "TimeoutSecondsPerRetry": 3
      },
      "CircuitBreaker": {
        "Enabled": true,
        "FailureRatio": 0.1,
        "MinimumThroughput": 10,
        "SamplingDurationSeconds": 100
      }
    }
  }
}
